# Firebase project ID (required for auth)
FIREBASE_PROJECT_ID=your-project-id

# Firebase project number (optional, but helps with token verification)
# Find it in Firebase Console → Project Settings → Project number
FIREBASE_PROJECT_NUMBER=

# CORS origins (comma-separated) — add your live frontend domain here too
CORS_ORIGINS=http://localhost:5173

# Admin API key (optional, for /ingest and /rebuild-index)
ADMIN_API_KEY=
